# ═══════════════════════════════════════════════════════════════════
# .gitignore — Content Agent System
# ═══════════════════════════════════════════════════════════════════

# ── SECRETS (jamais dans le repo) ──────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environnements virtuels ─────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ── uv ─────────────────────────────────────────────────────────────
# uv.lock DOIT être commité (reproductibilité des builds)
# mais pas le cache uv local
.uv/

# ── Tests & qualité ────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# ── Data & logs (montés en volumes Docker) ──────────────────────────
data/logs/
data/schedule.json
data/outreach.json
data/linkedin_cookies.json
data/medium_published.json
data/outreach_daily.json
schedule.json
logs/
*.log

# ── Playwright ─────────────────────────────────────────────────────
# Screenshots et traces de debug Playwright
playwright-report/
test-results/
.playwright/

# ── IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ── Docker ─────────────────────────────────────────────────────────
# Les fichiers Docker sont versionnés, pas les données des containers
docker-compose.override.yml
