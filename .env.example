# ──────────────────────────────────────────────────────────────────
# Content Agent System — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ──────────────────────────────────────────────────────────────────

# ── Provider LLM ───────────────────────────────────────────────────
# Choix du provider : "anthropic" (défaut) ou "openai"
# Peut aussi être changé directement dans l'UI sans redémarrer.
LLM_PROVIDER=anthropic

# [REQUIS si LLM_PROVIDER=anthropic] Clé API Anthropic
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# [REQUIS si LLM_PROVIDER=openai] Clé API OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# [OPTIONNEL] LinkedIn Publishing via API
# Access Token OAuth 2.0 (scope: w_member_social)
# Guide: https://learn.microsoft.com/en-us/linkedin/marketing/getting-started
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXX

# [OPTIONNEL] LinkedIn Outreach via Playwright (Phase 3)
# Pré-remplit la sidebar dans l'UI — peut aussi être saisi directement dedans
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# [OPTIONNEL] Autopublication LinkedIn des posts approuvés et arrivés à date
# Si activé, un worker scanne data/schedule.json et publie les posts "approved"
# dont scheduled_date <= aujourd'hui.
LINKEDIN_AUTOPUBLISH_ENABLED=false
LINKEDIN_AUTOPUBLISH_INTERVAL_SECONDS=300
LINKEDIN_AUTOPUBLISH_HEADLESS=true
LINKEDIN_AUTOPUBLISH_MAX_POSTS=0

# [OPTIONNEL] Medium Publishing
# Integration Token — https://medium.com/me/settings (section "Integration tokens")
MEDIUM_INTEGRATION_TOKEN=

# [OPTIONNEL] Config
LOG_LEVEL=INFO
ENVIRONMENT=development
LOG_DIR=data/logs
DATABASE_PATH=data/app.db
